root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

# 4-space indent because this is rustfmt's default
[*.rs]
indent_style = space
indent_size = 4

# 2-space indent because that's what github is using by default
[*.{yml,yaml,toml}]
indent_style = space
indent_size = 2
